# NutriAI Backend - Environment Configuration

# ============================================
# LLM Configuration
# ============================================

# GitHub Token para GitHub Models (obrigatório)
# Obtenha em: https://github.com/settings/tokens
GITHUB_TOKEN=""

# Modelo de LLM a ser usado
# Opções: github-models/openai/gpt-4.1-mini, openai/gpt-4o, etc.
MODEL="github-models/openai/gpt-4.1-mini"

# OpenAI API Key (alternativo ao GitHub Models)
OPENAI_API_KEY=""

# ============================================
# Auth Configuration (Better Auth)
# ============================================

# Backend URL (Better Auth base URL + JWT issuer)
BACKEND_URL="http://localhost:4111"

# PostgreSQL connection string (Better Auth database)
DATABASE_URL="postgresql://nutriauser:nutriapass@localhost:5432/nutriadb"

# Better Auth secret for signing sessions
BETTER_AUTH_SECRET=""

# Frontend URL (trusted origin for CORS)
FRONTEND_URL="http://localhost:3000"

# ============================================
# Food Catalog API Configuration
# ============================================

# URL da API de catálogo de alimentos
# Default: http://localhost:8000 (desenvolvimento local)
CATALOG_API_URL="http://localhost:8000"

# Timeout para requisições (em ms)
CATALOG_API_TIMEOUT="5000"

# Número de tentativas em caso de falha
CATALOG_API_RETRY_ATTEMPTS="3"

# Delay entre tentativas (em ms)
CATALOG_API_RETRY_DELAY="1000"

# ============================================
# Mastra Memory Configuration
# ============================================

# LibSQL URLs para Memory storage e vector database
# Padrão: file-based (desenvolvimento local)
MASTRA_STORAGE_URL="file:./nutrition-memory.db"
MASTRA_VECTOR_URL="file:./nutrition-vector.db"

# Para usar LibSQL remoto (Turso), use formato:
# MASTRA_STORAGE_URL="libsql://[name].turso.io"
# MASTRA_VECTOR_URL="libsql://[name]-vector.turso.io"

# ============================================
# Prompt Configuration (A/B Testing)
# ============================================

# Versão dos prompts do agente
# - compact: Versão otimizada (~250 tokens, 87% economia)
# - full: Versão completa (~2000 tokens, mais detalhada)
PROMPT_VERSION="compact"

# ============================================
# Debug
# ============================================

# Ativa logs extras de debug
DEBUG="false"

# Ambiente (development, production, test)
NODE_ENV="development"
