# Frontend URL (Better Auth base URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend Mastra URL (chat API)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4111

# Catalog API URL (meal plans, recipes)
CATALOG_API_URL=http://localhost:8000

# PostgreSQL (Better Auth database)
DATABASE_URL=postgresql://user:password@localhost:5432/nutria

# Better Auth secret (gere com: openssl rand -base64 32)
BETTER_AUTH_SECRET=
